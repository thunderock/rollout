{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunConfig",
  "description": "Top-level run configuration.",
  "type": "object",
  "properties": {
    "algorithm": {
      "description": "Algorithm and its settings.",
      "$ref": "#/$defs/AlgorithmConfig"
    },
    "run": {
      "description": "Free-form metadata about the run.",
      "$ref": "#/$defs/RunMetadata",
      "default": {
        "name": null,
        "tags": []
      }
    },
    "schema_version": {
      "description": "Schema version. v1 refuses configs with version > 1.",
      "type": "integer",
      "format": "uint32",
      "default": 1,
      "maximum": 1,
      "minimum": 1
    },
    "storage": {
      "description": "Storage backend selection.",
      "$ref": "#/$defs/StorageConfig"
    }
  },
  "additionalProperties": false,
  "required": [
    "storage",
    "algorithm"
  ],
  "$defs": {
    "AlgorithmConfig": {
      "description": "Algorithm selection.",
      "oneOf": [
        {
          "description": "Supervised fine-tuning.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "sft"
            },
            "learning_rate": {
              "description": "Learning rate override.",
              "type": [
                "number",
                "null"
              ],
              "format": "double",
              "default": null
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        },
        {
          "description": "Proximal policy optimization.",
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "ppo"
            },
            "kl_coef_init": {
              "description": "Initial KL coefficient.",
              "type": [
                "number",
                "null"
              ],
              "format": "double",
              "default": null
            }
          },
          "additionalProperties": false,
          "required": [
            "kind"
          ]
        }
      ]
    },
    "RunMetadata": {
      "description": "Free-form run metadata; persisted but not interpreted by the framework.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Human-readable run name.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "tags": {
          "description": "Free-form tags.",
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "StorageConfig": {
      "description": "Storage backend selection.",
      "oneOf": [
        {
          "description": "Embedded local KV (sled/redb — choice locked in Phase 2).",
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "const": "embedded"
            },
            "path": {
              "description": "Filesystem path for the embedded DB.",
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "backend",
            "path"
          ]
        },
        {
          "description": "Postgres URL (lands in Phase 4 / TRAIN-04).",
          "type": "object",
          "properties": {
            "backend": {
              "type": "string",
              "const": "postgres"
            },
            "url": {
              "description": "Postgres connection URL.",
              "type": "string"
            }
          },
          "additionalProperties": false,
          "required": [
            "backend",
            "url"
          ]
        }
      ]
    }
  }
}
